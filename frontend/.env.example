# ---- Public (exposed to browser) ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---- Server-only (never sent to browser) ----
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gemini / Vertex AI
GOOGLE_APPLICATION_CREDENTIALS=gcp-credentials.json
GCP_PROJECT_ID=your-gcp-project
GCP_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash
USE_VERTEX_AI=true

# Features
ENABLE_VIDEO_OCR=true
# Long videos: use sampled JPEG frames instead of sending the full file to Gemini (default 600s = 10 min)
VISUAL_FULL_VIDEO_MAX_SECONDS=600
VISUAL_SAMPLE_FRAME_COUNT=18
VISUAL_ANALYSIS_TIMEOUT_MS=240000
COMPLIANCE_MODE=clean

# Transcription (Gemini chunked long audio)
TRANSCRIBE_CHUNK_SEC=480
TRANSCRIBE_CHUNK_OVERLAP_SEC=15
TRANSCRIBE_GAP_THRESHOLD_SEC=45
TRANSCRIBE_GAP_FILL_ENABLED=true
TRANSCRIBE_GAP_FILL_MAX_SEC=300
# Tier B: not implemented — leave false
SPEECH_TO_TEXT_PRIMARY=false

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_PORTAL_RETURN_URL=https://accesslecture.com

# Plan limits
FREE_LECTURES_PER_MONTH=3
