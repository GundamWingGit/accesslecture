SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local dev: redis://localhost:6379/0 | Docker Compose: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# Vertex AI (preferred) — place JSON key at backend/gcp-credentials.json (gitignored)
USE_VERTEX_AI=true
GOOGLE_APPLICATION_CREDENTIALS=gcp-credentials.json
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# Fallback when USE_VERTEX_AI=false
GOOGLE_API_KEY=

WHISPER_MODEL_SIZE=large-v3
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=float16

HF_TOKEN=your-huggingface-token

COMPLIANCE_MODE=clean

# Optional: explicit path to rubric (Docker default: /docs/compliance-rubric.json)
# COMPLIANCE_RUBRIC_PATH=

# CORS: exact origins (comma-separated). Regex covers all *.vercel.app previews + production.
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app
