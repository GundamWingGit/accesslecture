SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local dev: redis://localhost:6379/0 | Docker Compose: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# Provider selection — swap AI components without touching the pipeline
# Phase 1: all "gemini"
# Phase 2: "speech_to_text" for transcription, "video_intelligence" for visual
TRANSCRIPTION_PROVIDER=gemini
VISUAL_ANALYSIS_PROVIDER=gemini
CLEANUP_PROVIDER=gemini

# Vertex AI (preferred) — place JSON key at backend/gcp-credentials.json (gitignored)
USE_VERTEX_AI=true
GOOGLE_APPLICATION_CREDENTIALS=gcp-credentials.json
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# Fallback when USE_VERTEX_AI=false
GOOGLE_API_KEY=

# Run video OCR when a video file is uploaded (set false to skip)
ENABLE_VIDEO_OCR=true

COMPLIANCE_MODE=clean

# Optional: explicit path to rubric (Docker default: /docs/compliance-rubric.json)
# COMPLIANCE_RUBRIC_PATH=

# CORS: exact origins (comma-separated). Regex covers all *.vercel.app previews + production.
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app
